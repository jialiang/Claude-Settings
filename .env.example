# Copy this file to `.env` (same directory) and fill in your own values.
# `.env` is gitignored and must never be committed.

# Gemini (Google AI Studio) — second-opinion AI, used by ~/.claude/scripts/gemini-ask.mjs.
# Free-tier key from https://aistudio.google.com/apikey. Model overridable; default is free Flash.
GEMINI_API_KEY=
GEMINI_MODEL=
