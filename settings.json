{
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1"
  },
  "permissions": {
    "defaultMode": "auto",
    "additionalDirectories": [
      "/tmp",
      "~/AppData/Local/Temp"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"process.stdout.write(JSON.stringify({hookSpecificOutput:{hookEventName:'UserPromptSubmit',additionalContext:'Reminder: follow the coding style preferences in ~/.claude/CLAUDE.md when writing or editing code. Re-read any files with uncommitted or manual changes before modifying them.'}}))\""
          },
          {
            "type": "command",
            "command": "node ~/.claude/scripts/usage-context.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/scripts/usage-context.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/scripts/usage-statusline.mjs",
    "refreshInterval": 30
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true
}
